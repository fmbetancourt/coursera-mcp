# Environment Configuration for Coursera MCP
# Copy this file to .env and fill in your values

# Runtime Environment
NODE_ENV=development
LOG_LEVEL=debug

# Coursera API Configuration
COURSERA_BASE_URL=https://api.coursera.org/api/onDemandCourses.v1
COURSERA_AUTH_URL=https://www.coursera.org/api/xAuthResetPasswordV1

# Claude API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Authentication
# TOTP Secret - generated during setup
TOTP_SECRET=

# Session Configuration
SESSION_TIMEOUT_MS=3600000
CACHE_TTL_SECONDS=300

# Logging
LOG_FORMAT=json
LOG_DIRECTORY=./logs

# Feature Flags
ENABLE_CACHE=true
ENABLE_CIRCUIT_BREAKER=true
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_MS=60000
